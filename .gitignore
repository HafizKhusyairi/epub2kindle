# Python cache
**/__pycache__/
**/*.py[cod]
**/*.pyo

# Build / packaging
dist/
build/
*.egg-info/
.eggs/

# Virtual environments
.venv/
venv/
env/

# Test & coverage
.pytest_cache/
.coverage
htmlcov/

# Type checkers / linters
.mypy_cache/
.ruff_cache/

# Hatch
.hatch/

# Docs — ignore top-level markdown except README
/*.md
!README.md
